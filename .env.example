# 和风天气API配置示例
# 请复制此文件为 .env.local 并填入您的实际配置

# 和风天气JWT Token（通过scripts/generate-jwt.js生成）
# 这应该是一个完整的JWT token，包含Header.Payload.Signature三部分
# 格式：eyJhbGciOiJFZERTQSIsImtpZCI6IllPVVJfS0lEIn0.eyJzdWIiOiJZT1VSX1BST0pFQ1RfSUQiLCJpYXQiOjE2ODg4ODg4ODgsImV4cCI6MTY4ODg5MjQ4OH0.signature_part
REACT_APP_QWEATHER_API_KEY=YOUR_JWT_TOKEN_HERE

# 和风天气API主机地址
# 免费版用户：https://devapi.qweather.com
# 付费版用户：https://api.qweather.com
# 专用API Host：https://your-host.qweatherapi.com
REACT_APP_QWEATHER_HOST=https://nn3yfpy58r.re.qweatherapi.com

# 配置说明：
# 1. 生成JWT Token：
#    - 进入 scripts 目录
#    - 配置 jwt-config.json 文件
#    - 运行 generate-jwt.bat 或 node generate-jwt.cjs
# 2. 将生成的JWT Token复制到上面的 REACT_APP_QWEATHER_API_KEY
# 3. 根据您的账户类型设置正确的 REACT_APP_QWEATHER_HOST
# 4. 保存文件为 .env.local（不要提交到版本控制）