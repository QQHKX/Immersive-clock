REACT_APP_QWEATHER_API_KEY=eyJhbGciOiJFZERTQSIsImtpZCI6IktENUJEQ1QyVFUifQ.eyJzdWIiOiIyNlRQUDdQNDlCIiwiaWF0IjoxNzU2NTY1MzA3LCJleHAiOjE3NTY2NTE3Mzd9.HpEyVMORzXtQ3yb-bU8rktZwwB-t-5NfzAI_lkGm7oT_GkonAR-J1-2fZrt8_LKjpbChFGc4wXVJYXcy_pUICQ

# 和风天气API主机地址
# 免费版用户：https://devapi.qweather.com
# 付费版用户：https://api.qweather.com
# 专用API Host：https://your-host.qweatherapi.com
REACT_APP_QWEATHER_HOST=https://nn3yfpy58r.re.qweatherapi.com

# 配置说明：
# 1. 此文件由GitHub Actions工作流自动维护
# 2. JWT Token每12小时自动更新
# 3. 手动修改可能会被自动覆盖
# 4. 本地开发请使用.env.local文件（不会被提交到版本控制）
